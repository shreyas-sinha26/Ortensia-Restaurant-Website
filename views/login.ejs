<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Log In - Urban Bites</title>
    <link href="https://fonts.googleapis.com/css2?family=Poppins:wght@300;400;500;600&display=swap" rel="stylesheet">
    <style>
        * {
            margin: 0;
            padding: 0;
            box-sizing: border-box;
            font-family: 'Poppins', sans-serif;
        }

        body {
            /* Brooke Lark's food photo with a dark overlay */
            background: linear-gradient(rgba(0, 0, 0, 0.65), rgba(0, 0, 0, 0.65)), 
                        url('/img/brooke-lark-aGjP08-HbYY-unsplash.jpg') no-repeat center center;
            background-size: cover;
            height: 100vh;
            display: flex;
            justify-content: center;
            align-items: center;
        }

        /* --- Back to Home Button --- */
        .back-home-btn {
            position: absolute;
            top: 30px;
            left: 30px;
            color: white;
            text-decoration: none;
            font-weight: 500;
            font-size: 15px;
            background: rgba(255, 255, 255, 0.15);
            padding: 10px 20px;
            border-radius: 30px;
            backdrop-filter: blur(10px);
            box-shadow: 0 4px 15px rgba(0,0,0,0.2);
            transition: all 0.3s ease;
            border: 1px solid rgba(255,255,255,0.2);
            /* Initially hidden for GSAP */
            opacity: 0;
            transform: translateX(-20px);
            z-index: 10;
        }

        .back-home-btn:hover {
            background: rgba(255, 255, 255, 0.25);
            transform: translateY(-2px) !important; /* overrides GSAP transform on hover */
        }

        /* --- Flash Message Toast Styles --- */
        .flash-container {
            position: fixed;
            top: 30px;
            left: 50%;
            transform: translateX(-50%);
            z-index: 1000;
            display: flex;
            flex-direction: column;
            gap: 15px;
            pointer-events: none; /* Let clicks pass through to the form */
            width: 90%;
            max-width: 400px;
        }
        
        .flash-message {
            background: rgba(255, 255, 255, 0.95);
            backdrop-filter: blur(10px);
            padding: 16px 24px;
            border-radius: 50px;
            box-shadow: 0 15px 35px rgba(0, 0, 0, 0.2);
            display: flex;
            align-items: center;
            gap: 12px;
            font-weight: 500;
            font-size: 15px;
            /* Initially hidden for GSAP */
            opacity: 0; 
            transform: translateY(-30px);
        }

        .flash-message.error {
            color: #d9534f;
            border-left: 5px solid #d9534f;
        }

        .flash-message.success {
            color: #28a745;
            border-left: 5px solid #28a745;
        }

        .flash-icon {
            font-size: 18px;
        }

        /* --- Form Styles --- */
        .form-container {
            background: rgba(255, 255, 255, 0.95);
            padding: 40px 30px;
            border-radius: 15px;
            box-shadow: 0 15px 35px rgba(0,0,0,0.3);
            width: 100%;
            max-width: 400px;
            text-align: center;
            /* Initially hidden for GSAP */
            opacity: 0; 
            transform: scale(0.9);
        }

        .form-container h2 {
            font-size: 28px;
            color: #333;
            margin-bottom: 30px;
        }

        .input-group {
            margin-bottom: 20px;
            text-align: left;
            /* Initially hidden for GSAP */
            opacity: 0; 
            transform: translateX(-30px);
        }

        .input-group label {
            display: block;
            margin-bottom: 8px;
            color: #555;
            font-weight: 500;
        }

        .input-group input {
            width: 100%;
            padding: 12px 15px;
            border: 1px solid #ddd;
            border-radius: 8px;
            font-size: 15px;
            transition: all 0.3s ease;
        }

        .input-group input:focus {
            border-color: #8e75c6;
            outline: none;
            box-shadow: 0 0 8px rgba(142, 117, 198, 0.4);
        }

        .submit-btn {
            width: 100%;
            padding: 12px;
            background: #8e75c6;
            color: white;
            border: none;
            border-radius: 8px;
            font-size: 16px;
            font-weight: 600;
            cursor: pointer;
            transition: background 0.3s;
            /* Initially hidden for GSAP */
            opacity: 0; 
            transform: translateY(20px);
        }

        .submit-btn:hover {
            background: #755bb0;
        }

        .signup-link {
            margin-top: 20px;
            font-size: 14px;
            color: #666;
            /* Initially hidden for GSAP */
            opacity: 0; 
        }

        .signup-link a {
            color: #8e75c6;
            text-decoration: none;
            font-weight: 600;
        }
    </style>
</head>
<body>

    <a href="/" class="back-home-btn">⬅ Back to Home</a>

    <div class="flash-container">
        <% if(typeof error !== 'undefined' && error.length > 0) { %>
            <div class="flash-message error">
                <span class="flash-icon">⚠️</span> 
                <span><%= error %></span>
            </div>
        <% } %>

        <% if(typeof success !== 'undefined' && success.length > 0) { %>
            <div class="flash-message success">
                <span class="flash-icon">✅</span> 
                <span><%= success %></span>
            </div>
        <% } %>
    </div>

    <div class="form-container">
        <h2>Welcome Back!</h2>
        
        <form action="/login" method="POST">
            <div class="input-group gsap-item">
                <label for="username">Username</label>
                <input type="text" id="username" name="username" placeholder="Enter your username" required>
            </div>
            <div class="input-group gsap-item">
                <label for="password">Password</label>
                <input type="password" id="password" name="password" placeholder="Enter your password" required>
            </div>
            <button type="submit" class="submit-btn gsap-btn">Log In</button>
        </form>
        <p class="signup-link gsap-link">Don't have an account? <a href="/signup">Sign Up</a></p>
    </div>

    <script src="https://cdnjs.cloudflare.com/ajax/libs/gsap/3.12.2/gsap.min.js"></script>
    <script>
        document.addEventListener("DOMContentLoaded", () => {
            // --- Back Button Animation ---
            gsap.to(".back-home-btn", {
                duration: 0.6,
                opacity: 1,
                x: 0,
                ease: "power2.out",
                delay: 0.1
            });

            // --- Flash Message Animation ---
            const flashMessages = document.querySelectorAll(".flash-message");
            if (flashMessages.length > 0) {
                const flashTimeline = gsap.timeline();
                
                flashTimeline.to(".flash-message", {
                    duration: 0.6,
                    opacity: 1,
                    y: 0,
                    stagger: 0.15,
                    ease: "back.out(1.5)"
                })
                .to(".flash-message", {
                    duration: 0.5,
                    opacity: 0,
                    y: -30,
                    stagger: 0.1,
                    ease: "power2.in",
                    delay: 3.5
                });
            }

            // --- Form Animations ---
            // Container pop-in
            gsap.to(".form-container", {
                duration: 0.6,
                opacity: 1,
                scale: 1,
                ease: "back.out(1.5)"
            });

            // Slide inputs from the left
            gsap.to(".gsap-item", {
                duration: 0.5,
                opacity: 1,
                x: 0,
                stagger: 0.15,
                ease: "power2.out",
                delay: 0.2
            });

            // Slide button from the bottom
            gsap.to(".gsap-btn", {
                duration: 0.5,
                opacity: 1,
                y: 0,
                ease: "power2.out",
                delay: 0.6
            });

            // Fade in the link
            gsap.to(".gsap-link", {
                duration: 0.5,
                opacity: 1,
                delay: 0.8
            });
        });
    </script>
</body>
</html>