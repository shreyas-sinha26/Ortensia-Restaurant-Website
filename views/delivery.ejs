<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Delivery - Ōrtensia</title>
    
    <link rel="preconnect" href="https://fonts.googleapis.com">
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
    <link href="https://fonts.googleapis.com/css2?family=Big+Shoulders+Text:wght@100;300;400;500;600;700;800;900&display=swap" rel="stylesheet">
    
    <link rel="stylesheet" href="/css/index.css">
    <link rel="stylesheet" href="/css/delivery.css">
</head>
<body>
    <header>
        <nav class="nav-flex-row">
            <div class="nav-brand">
                <a href="/">Ōrtensia</a>
            </div>
            <ul class="nav-links">
                <li><a href="/">Home</a></li>
                <li><a href="/menu">Menu</a></li>
                <li><a href="/delivery" class="active">Delivery</a></li>
                <li><a href="/reservation">Reservation</a></li>
            </ul>
        </nav>
    </header>

    <main class="page-container">
        <div class="form-card">
            <h2 class="page-title">Delivery Details</h2>
            <p class="page-subtitle">We will deliver your order hot and fresh right to your doorstep.</p>
            
            <form action="/delivery" method="POST" class="elegant-form">
                <div class="form-group">
                    <label for="name">Full Name</label>
                    <input type="text" id="name" name="name" required placeholder="John Doe">
                </div>
                <div class="form-group">
                    <label for="phone">Phone Number</label>
                    <input type="tel" id="phone" name="phone" required placeholder="+1 234 567 8900">
                </div>
                <div class="form-group">
                    <label for="address">Delivery Address</label>
                    <textarea id="address" name="address" rows="3" required placeholder="123 Main St, Apt 4B"></textarea>
                </div>
                <button type="submit" class="btn-primary">Proceed to Order</button>
            </form>
        </div>
    </main>

</body>
</html>