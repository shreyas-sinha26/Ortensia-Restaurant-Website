<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Reservation - Ōrtensia</title>
    
    <link rel="preconnect" href="https://fonts.googleapis.com">
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
    <link href="https://fonts.googleapis.com/css2?family=Big+Shoulders+Text:wght@100;300;400;500;600;700;800;900&display=swap" rel="stylesheet">
    
    <link rel="stylesheet" href="/css/index.css">
    <link rel="stylesheet" href="/css/reservations.css">
</head>
<body>
    <header>
        <nav class="nav-flex-row">
            <div class="nav-brand">
                <a href="/">Ōrtensia</a>
            </div>
            <ul class="nav-links">
                <li><a href="/">Home</a></li>
                <li><a href="/menu">Menu</a></li>
                <li><a href="/delivery">Delivery</a></li>
                <li><a href="/reservation" class="active">Reservation</a></li>
            </ul>
        </nav>
    </header>

    <main class="page-container">
        <div class="form-card">
            <h2 class="page-title">Book a Table</h2>
            <p class="page-subtitle">Reserve your spot at Ōrtensia for an unforgettable dining experience.</p>
            
            <form action="/reservation" method="POST" class="elegant-form">
                <div class="form-group">
                    <label for="name">Name</label>
                    <input type="text" id="name" name="name" required placeholder="Your Name">
                </div>
                <div class="form-group">
                    <label for="date">Date</label>
                    <input type="date" id="date" name="date" required>
                </div>
                <div class="form-group">
                    <label for="time">Time</label>
                    <input type="time" id="time" name="time" required>
                </div>
                <div class="form-group">
                    <label for="guests">Number of Guests</label>
                    <input type="number" id="guests" name="guests" min="1" max="20" required placeholder="2">
                </div>
                <button type="submit" class="btn-primary">Confirm Reservation</button>
            </form>
        </div>
    </main>
</body>
</html>